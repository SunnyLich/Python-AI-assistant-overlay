# Copy this file to .env and fill in your keys
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CARTESIA_API_KEY=your_cartesia_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# LLM (hotkey queries — optimise for low latency)
LLM_PROVIDER=groq
LLM_MODEL=llama3-8b-8192

# Chat / Elaborate model (defaults to LLM_PROVIDER / LLM_MODEL if not set)
# Use a larger model here when latency matters less and quality matters more
# e.g. CHAT_LLM_MODEL=llama-3.3-70b-versatile
CHAT_LLM_PROVIDER=groq
CHAT_LLM_MODEL=llama3-8b-8192

# Vision LLM (screen-snip queries — Ctrl+Alt+Q — must support image input)
# Required to use the snip feature; leave blank to get a helpful error at runtime.
# Recommended: anthropic + claude-opus-4-5  |  or openai + gpt-4o
VISION_LLM_PROVIDER=anthropic
VISION_LLM_MODEL=claude-opus-4-5

# TTS provider: cartesia | elevenlabs | none
TTS_PROVIDER=none
CARTESIA_VOICE_ID=your_voice_id_here

# Hotkeys
HOTKEY_INVOKE=ctrl+q
HOTKEY_ADD_CONTEXT=alt+q
HOTKEY_CLEAR_CONTEXT=alt+w
HOTKEY_SNIP=ctrl+alt+q

# App behaviour
DOLL_AUTO_HIDE=true
CHAT_AUTO_ELABORATE=true
CHAT_ELABORATE_PROMPT=Please elaborate on that.
